{
  "redirects": [
    { "source": "/:path*", "has": [{"type": "host", "value": "www.reactionspeedtest.com"}], "destination": "https://reactionspeedtest.com/:path*", "permanent": true },
    { "source": "/:path*", "has": [{"type": "header", "key": "x-forwarded-proto", "value": "http"}], "destination": "https://reactionspeedtest.com/:path*", "permanent": true }
  ],
  "rewrites": [
    { "source": "/reaction-time-test",  "destination": "/reaction-time-test.html" },
    { "source": "/click-speed-test",    "destination": "/click-speed-test.html" },
    { "source": "/jitter-click-test",   "destination": "/jitter-click-test.html" },
    { "source": "/spacebar-speed-test", "destination": "/spacebar-speed-test.html" },
    { "source": "/stimulation-clicker", "destination": "/stimulation-clicker.html" },
    { "source": "/typing-speed-test",   "destination": "/typing-speed-test.html" },
    { "source": "/dinosaur-game",       "destination": "/dinosaur-game.html" },
    { "source": "/coreball-game",       "destination": "/coreball-game.html" },
    { "source": "/number-memory-test",  "destination": "/number-memory-test.html" },
    { "source": "/snake-game",          "destination": "/snake-game.html" },
    { "source": "/clicker-tycoon",      "destination": "/clicker-tycoon.html" },
    { "source": "/about",               "destination": "/about.html" },
    { "source": "/privacy-policy",      "destination": "/privacy-policy.html" },
    { "source": "/contact",             "destination": "/contact.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
